{
  "title": "SGLang",
  "description": "A fast serving framework for large language models and vision language models.",
  "type": "serverless",
  "category": "language",
  "iconUrl": "https://avatars.githubusercontent.com/u/147780389?v=4",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 100,
    "gpuIds": "ADA_24",
    "gpuCount": 1,
    "allowedCudaVersions": ["12.9", "12.8", "12.7", "12.6"],
    "env": [
      {
        "key": "MODEL_NAME",
        "input": {
          "name": "Model",
          "type": "huggingface",
          "description": "Hugging Face model name",
          "required": true
        }
      },
      {
        "key": "QUANTIZATION",
        "input": {
          "name": "Quantization",
          "type": "string",
          "description": "Quantization method. Leave EMPTY for pre-quantized FP8 models (e.g. Qwen3-VL-8B-Instruct-FP8). Only set for models that need runtime quantization.",
          "default": "",
          "required": false,
          "options": [
            { "value": "awq", "label": "AWQ" },
            { "value": "fp8", "label": "FP8" },
            { "value": "gptq", "label": "GPTQ" },
            { "value": "marlin", "label": "Marlin" },
            { "value": "gptq_marlin", "label": "GPTQ Marlin" },
            { "value": "awq_marlin", "label": "AWQ Marlin" },
            { "value": "squeezellm", "label": "SqueezeLLM" },
            { "value": "bitsandbytes", "label": "BitsAndBytes" }
          ],
          "advanced": true
        }
      },
      {
        "key": "TRUST_REMOTE_CODE",
        "input": {
          "name": "Trust Remote Code",
          "type": "boolean",
          "description": "Allow custom models from Hub. REQUIRED for Qwen3-VL models.",
          "default": true,
          "required": false
        }
      },
      {
        "key": "ATTENTION_BACKEND",
        "input": {
          "name": "Attention Backend",
          "type": "string",
          "description": "Attention computation backend for text tokens. 'flashinfer' recommended for RTX 4090.",
          "default": "flashinfer",
          "required": false,
          "options": [
            { "value": "flashinfer", "label": "FlashInfer" },
            { "value": "triton", "label": "Triton" },
            { "value": "torch_native", "label": "Torch Native" },
            { "value": "fa3", "label": "FA3" },
            { "value": "fa4", "label": "FA4" }
          ],
          "advanced": true
        }
      },
      {
        "key": "MM_ATTENTION_BACKEND",
        "input": {
          "name": "Multimodal Attention Backend",
          "type": "string",
          "description": "Attention backend for multimodal (image/video) tokens. Leave empty for auto-detect. Use 'triton_attn' for RTX 4090 if default fails.",
          "default": "",
          "required": false,
          "options": [
            { "value": "", "label": "Auto-detect" },
            { "value": "triton_attn", "label": "Triton" },
            { "value": "fa3", "label": "FA3" },
            { "value": "fa4", "label": "FA4" },
            { "value": "sdpa", "label": "SDPA" }
          ],
          "advanced": true
        }
      },
      {
        "key": "SAMPLING_BACKEND",
        "input": {
          "name": "Sampling Backend",
          "type": "string",
          "description": "Sampling computation backend",
          "default": "flashinfer",
          "required": false,
          "options": [
            { "value": "flashinfer", "label": "FlashInfer" },
            { "value": "torch", "label": "Torch" }
          ],
          "advanced": true
        }
      },
      {
        "key": "FILE_STORAGE_PATH",
        "input": {
          "name": "File Storage Path",
          "type": "string",
          "description": "Path for storing uploaded files (images/videos for VLM). REQUIRED for vision models like Qwen3-VL.",
          "default": "/runpod-volume/file-storage",
          "required": false
        }
      },
      {
        "key": "REASONING_PARSER",
        "input": {
          "name": "Reasoning Parser",
          "type": "string",
          "description": "Parser for reasoning/thinking content. Use 'qwen3' for Qwen3 models, 'qwen3-thinking' for Qwen3-Thinking models.",
          "default": "",
          "required": false,
          "advanced": true,
          "options": [
            { "value": "", "label": "None" },
            { "value": "qwen3", "label": "qwen3 (Qwen3 standard)" },
            { "value": "qwen3-thinking", "label": "qwen3-thinking (Qwen3 Thinking)" },
            { "value": "deepseek-r1", "label": "deepseek-r1" },
            { "value": "deepseek-v3", "label": "deepseek-v3" },
            { "value": "qwen25", "label": "qwen25 (Qwen2.5 only)" }
          ]
        }
      },
      {
        "key": "TOOL_CALL_PARSER",
        "input": {
          "name": "Tool Call Parser",
          "type": "string",
          "description": "Defines the parser used to interpret tool call responses",
          "default": "",
          "required": false,
          "advanced": true,
          "options": [
            { "value": "llama3", "label": "llama3" },
            { "value": "llama4", "label": "llama4" },
            { "value": "mistral", "label": "mistral" },
            { "value": "qwen25", "label": "qwen25" },
            { "value": "deepseekv3", "label": "deepseekv3" }
          ]
        }
      },
      {
        "key": "TOKENIZER_PATH",
        "input": {
          "name": "Tokenizer Path",
          "type": "string",
          "description": "Path of the tokenizer",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "TOKENIZER_MODE",
        "input": {
          "name": "Tokenizer Mode",
          "type": "string",
          "description": "Tokenizer mode",
          "default": "auto",
          "required": false,
          "options": [
            { "value": "auto", "label": "auto" },
            { "value": "slow", "label": "slow" }
          ],
          "advanced": true
        }
      },
      {
        "key": "LOAD_FORMAT",
        "input": {
          "name": "Load Format",
          "type": "string",
          "description": "Format of model weights to load",
          "default": "auto",
          "required": false,
          "options": [
            { "value": "auto", "label": "auto" },
            { "value": "pt", "label": "pt" },
            { "value": "safetensors", "label": "safetensors" },
            { "value": "npcache", "label": "npcache" },
            { "value": "dummy", "label": "dummy" }
          ],
          "advanced": true
        }
      },
      {
        "key": "DTYPE",
        "input": {
          "name": "Data Type",
          "type": "string",
          "description": "Data type for weights and activations. Use 'auto' for FP8 pre-quantized models.",
          "default": "auto",
          "required": false,
          "options": [
            { "value": "auto", "label": "auto" },
            { "value": "half", "label": "half" },
            { "value": "float16", "label": "float16" },
            { "value": "bfloat16", "label": "bfloat16" },
            { "value": "float", "label": "float" },
            { "value": "float32", "label": "float32" }
          ],
          "advanced": true
        }
      },
      {
        "key": "CONTEXT_LENGTH",
        "input": {
          "name": "Context Length",
          "type": "number",
          "description": "Model's maximum context length. 8192 is a good balance for RTX 4090 (24GB) with VLM.",
          "default": 8192,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "SERVED_MODEL_NAME",
        "input": {
          "name": "Served Model Name",
          "type": "string",
          "description": "Override model name in API",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "CHAT_TEMPLATE",
        "input": {
          "name": "Chat Template",
          "type": "string",
          "description": "Chat template name or path",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "MEM_FRACTION_STATIC",
        "input": {
          "name": "Memory Fraction Static",
          "type": "number",
          "description": "Fraction of GPU memory for model weights. 0.85 for RTX 4090 with FP8 VLM + 10 concurrent users.",
          "default": 0.85,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "MAX_RUNNING_REQUESTS",
        "input": {
          "name": "Max Running Requests",
          "type": "number",
          "description": "Maximum concurrent requests processed by sglang. Set to 10 for 10 concurrent users.",
          "default": 10,
          "required": false
        }
      },
      {
        "key": "MAX_TOTAL_TOKENS",
        "input": {
          "name": "Max Total Tokens",
          "type": "number",
          "description": "Maximum tokens in memory pool. Balances concurrency vs. per-request capacity.",
          "default": 8192,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "CHUNKED_PREFILL_SIZE",
        "input": {
          "name": "Chunked Prefill Size",
          "type": "number",
          "description": "Max tokens per chunk in chunked prefill. Lower = less VRAM spike per request.",
          "default": 512,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "MAX_PREFILL_TOKENS",
        "input": {
          "name": "Max Prefill Tokens",
          "type": "number",
          "description": "Max tokens in prefill batch across all requests.",
          "default": 4096,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "SCHEDULE_POLICY",
        "input": {
          "name": "Schedule Policy",
          "type": "string",
          "description": "Request scheduling policy. 'lpm' (longest-prefix-match) is best for VLMs with image prefix reuse.",
          "default": "lpm",
          "required": false,
          "options": [
            { "value": "lpm", "label": "LPM" },
            { "value": "random", "label": "Random" },
            { "value": "fcfs", "label": "FCFS" },
            { "value": "dfs-weight", "label": "DFS Weight" }
          ],
          "advanced": true
        }
      },
      {
        "key": "SCHEDULE_CONSERVATIVENESS",
        "input": {
          "name": "Schedule Conservativeness",
          "type": "number",
          "description": "Conservativeness of schedule policy (0.0 to 1.0). Higher = more conservative memory use.",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "TENSOR_PARALLEL_SIZE",
        "input": {
          "name": "Tensor Parallel Size",
          "type": "number",
          "description": "Tensor parallelism size. Use 1 for single GPU (RTX 4090).",
          "default": 1,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "STREAM_INTERVAL",
        "input": {
          "name": "Stream Interval",
          "type": "number",
          "description": "Streaming interval in token length",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "RANDOM_SEED",
        "input": {
          "name": "Random Seed",
          "type": "number",
          "description": "Random seed",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "LOG_LEVEL",
        "input": {
          "name": "Log Level",
          "type": "string",
          "description": "Logging level for all loggers",
          "default": "info",
          "required": false,
          "options": [
            { "value": "debug", "label": "Debug" },
            { "value": "info", "label": "Info" },
            { "value": "warning", "label": "Warning" },
            { "value": "error", "label": "Error" }
          ]
        }
      },
      {
        "key": "LOG_LEVEL_HTTP",
        "input": {
          "name": "HTTP Log Level",
          "type": "string",
          "description": "Logging level for HTTP server",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "API_KEY",
        "input": {
          "name": "API Key",
          "type": "string",
          "description": "API key for the server",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "DATA_PARALLEL_SIZE",
        "input": {
          "name": "Data Parallel Size",
          "type": "number",
          "description": "Data parallelism size",
          "default": "",
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "LOAD_BALANCE_METHOD",
        "input": {
          "name": "Load Balance Method",
          "type": "string",
          "description": "Load balancing strategy",
          "default": "",
          "required": false,
          "options": [
            { "value": "round_robin", "label": "Round Robin" },
            { "value": "shortest_queue", "label": "Shortest Queue" }
          ],
          "advanced": true
        }
      },
      {
        "key": "SKIP_TOKENIZER_INIT",
        "input": {
          "name": "Skip Tokenizer Init",
          "type": "boolean",
          "description": "Skip tokenizer init",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "LOG_REQUESTS",
        "input": {
          "name": "Log Requests",
          "type": "boolean",
          "description": "Log inputs and outputs of requests",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "SHOW_TIME_COST",
        "input": {
          "name": "Show Time Cost",
          "type": "boolean",
          "description": "Show time cost of custom marks",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "DISABLE_RADIX_CACHE",
        "input": {
          "name": "Disable Radix Cache",
          "type": "boolean",
          "description": "Disable RadixAttention for prefix caching.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "DISABLE_CUDA_GRAPH",
        "input": {
          "name": "Disable CUDA Graph",
          "type": "boolean",
          "description": "Disable cuda graph. Enable if you encounter CUDA OOM on startup.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "DISABLE_OUTLINES_DISK_CACHE",
        "input": {
          "name": "Disable Outlines Disk Cache",
          "type": "boolean",
          "description": "Disable disk cache of outlines",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_MULTIMODAL",
        "input": {
          "name": "Enable Multimodal",
          "type": "boolean",
          "description": "Explicitly enable multimodal (VLM) support. Usually auto-detected, but set to true for Qwen3-VL if images fail.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "KEEP_MM_FEATURE_ON_DEVICE",
        "input": {
          "name": "Keep MM Feature On Device",
          "type": "boolean",
          "description": "Keep multimodal (image) features on GPU after processing. Improves speed but uses more VRAM.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "DISABLE_FAST_IMAGE_PROCESSOR",
        "input": {
          "name": "Disable Fast Image Processor",
          "type": "boolean",
          "description": "Use base image processor instead of fast one. Enable if image processing errors occur.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_TORCH_COMPILE",
        "input": {
          "name": "Enable Torch Compile",
          "type": "boolean",
          "description": "Optimize model with torch.compile. Increases startup time but may improve throughput.",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_P2P_CHECK",
        "input": {
          "name": "Enable P2P Check",
          "type": "boolean",
          "description": "Enable P2P check for GPU access",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_FLASHINFER_MLA",
        "input": {
          "name": "Enable FlashInfer MLA",
          "type": "boolean",
          "description": "Enable FlashInfer Multi-head Latent Attention",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "TRITON_ATTENTION_REDUCE_IN_FP32",
        "input": {
          "name": "Triton Attention Reduce in FP32",
          "type": "boolean",
          "description": "Cast Triton attention results to fp32",
          "default": false,
          "required": false,
          "advanced": true
        }
      },
      {
        "key": "MAX_CONCURRENCY",
        "input": {
          "name": "Max Concurrency (RunPod Workers)",
          "type": "number",
          "description": "Maximum number of concurrent RunPod serverless workers. Set to 10 for 10 concurrent users.",
          "default": 10,
          "required": false
        }
      }
    ]
  }
}